{
  "schemaVersion": 1,
  "id": "yqcterminal",
  "version": "${version}",
  "name": "Yqloss Client Terminal",
  "description": "qterm",
  "authors": ["Yqloss"],
  "environment": "client",
  "entrypoints": {
    "client": [
      {
        "adapter": "kotlin",
        "value": "net.yqloss.yqcterminal.YqlossMainKt::init"
      }
    ]
  },
  "depends": {
    "fabricloader": ">=${loader_version}",
    "fabric-api": ">=${fabric_api_version}",
    "minecraft": "~${minecraft_version}",
    "fabric-language-kotlin": ">=${fabric_kotlin_version}",
    "odin": "*"
  }
}
